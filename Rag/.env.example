# OpenAI-compatible model service (required)
LLM_BASE_URL=https://your-openai-compatible-endpoint
LLM_MODEL=your-model-name
LLM_API_KEY=replace-with-your-api-key

# Browser origins allowed to access the API, comma separated
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://127.0.0.1:5173,http://localhost:5173

# Neo4j
# For a local backend, keep localhost. Docker Compose replaces this with neo4j.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-strong-password
NEO4J_DATABASE=neo4j

# Milvus
# For a local backend, keep localhost. Docker Compose replaces this with milvus.
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=cooking_knowledge

# MinIO credentials used by Docker Compose only. They must remain unchanged after
# the MinIO data volume has been initialized, unless you migrate or recreate it.
MINIO_ACCESS_KEY=replace-with-a-minio-username
MINIO_SECRET_KEY=replace-with-a-strong-minio-password

# Frontend build-time API address. Set it in the deployment platform for production.
VITE_API_BASE_URL=http://localhost:7860
